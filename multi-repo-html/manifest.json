{
  "version": "1.0",
  "description": "HTML Design System manifest — maps components to platform implementations, variant enums, and data attributes",
  "components": {
    "Button": {
      "category": "atomic",
      "description": "Primary interaction element with multiple types and states",
      "platforms": {
        "web": "app/components/Button/Button.tsx",
        "ios": "Components/Button/AppButton.swift",
        "android": "ui/components/AppButton.kt"
      },
      "html": {
        "css": "components/button/button.css",
        "snippet": "components/button/button.html",
        "tag": "button",
        "classPrefix": "ds-button"
      },
      "variants": {
        "type": ["primary", "secondary", "tertiary", "success", "danger"],
        "size": ["sm", "md", "lg"],
        "state": ["default", "hover", "pressed", "disabled"]
      },
      "dataAttributes": ["data-component", "data-variant", "data-size", "data-state"]
    },
    "IconButton": {
      "category": "atomic",
      "description": "Icon-only button with multiple types, sizes, and states",
      "platforms": {
        "web": "app/components/IconButton/IconButton.tsx",
        "ios": "Components/IconButton/AppIconButton.swift",
        "android": "ui/components/AppIconButton.kt"
      },
      "html": {
        "css": "components/icon-button/icon-button.css",
        "snippet": "components/icon-button/icon-button.html",
        "tag": "button",
        "classPrefix": "ds-icon-button"
      },
      "variants": {
        "type": ["primary", "secondary", "tertiary", "quarternary", "success", "danger"],
        "size": ["sm", "md", "lg"],
        "state": ["default", "hover", "pressed", "disabled"]
      },
      "dataAttributes": ["data-component", "data-variant", "data-size", "data-state"]
    },
    "Badge": {
      "category": "atomic",
      "description": "Status or count indicator with type and subtle variants",
      "platforms": {
        "web": "app/components/Badge/Badge.tsx",
        "ios": "Components/Badge/AppBadge.swift",
        "android": "ui/components/AppBadge.kt"
      },
      "html": {
        "css": "components/badge/badge.css",
        "snippet": "components/badge/badge.html",
        "tag": "span",
        "classPrefix": "ds-badge"
      },
      "variants": {
        "size": ["tiny", "sm", "number", "md"],
        "type": ["brand", "success", "error", "accent"],
        "subtle": ["off", "on"]
      },
      "dataAttributes": ["data-component", "data-variant", "data-size", "data-subtle"]
    },
    "Label": {
      "category": "atomic",
      "description": "Text label with icon slot, multiple sizes and semantic types",
      "platforms": {
        "web": "app/components/Label/Label.tsx",
        "ios": "Components/Label/AppLabel.swift",
        "android": "ui/components/AppLabel.kt"
      },
      "html": {
        "css": "components/label/label.css",
        "snippet": "components/label/label.html",
        "tag": "span",
        "classPrefix": "ds-label"
      },
      "variants": {
        "size": ["sm", "md", "lg"],
        "type": ["secondary-action", "primary-action", "brand-interactive", "information"]
      },
      "dataAttributes": ["data-component", "data-variant", "data-size"]
    },
    "Chip": {
      "category": "atomic",
      "description": "Selectable chip for tabs, filters, or segment control",
      "platforms": {
        "web": "app/components/Chip/Chip.tsx",
        "ios": "Components/Chip/AppChip.swift",
        "android": "ui/components/AppChip.kt"
      },
      "html": {
        "css": "components/chip/chip.css",
        "snippet": "components/chip/chip.html",
        "tag": "button",
        "classPrefix": "ds-chip"
      },
      "variants": {
        "type": ["chip-tabs", "filters", "segment-control"],
        "size": ["sm", "md", "lg"],
        "state": ["default", "hover", "active", "disabled"]
      },
      "dataAttributes": ["data-component", "data-variant", "data-size", "data-active", "data-state"]
    },
    "Tabs": {
      "category": "atomic",
      "description": "Tab bar with individual tab items, sizes, and active state",
      "platforms": {
        "web": "app/components/Tabs/Tabs.tsx",
        "ios": "Components/Tabs/AppTabs.swift",
        "android": "ui/components/AppTabs.kt"
      },
      "html": {
        "css": "components/tabs/tabs.css",
        "snippet": "components/tabs/tabs.html",
        "tag": "div",
        "classPrefix": "ds-tab-bar"
      },
      "variants": {
        "size": ["sm", "md", "lg"],
        "state": ["default", "hover", "active"]
      },
      "dataAttributes": ["data-component", "data-size", "data-active"]
    },
    "SegmentControlBar": {
      "category": "atomic",
      "description": "Container bar for segment control, chips, or filters",
      "platforms": {
        "web": "app/components/SegmentControlBar/SegmentControlBar.tsx",
        "ios": "Components/SegmentControlBar/AppSegmentControlBar.swift",
        "android": "ui/components/AppSegmentControlBar.kt"
      },
      "html": {
        "css": "components/segment-control-bar/segment-control-bar.css",
        "snippet": "components/segment-control-bar/segment-control-bar.html",
        "tag": "div",
        "classPrefix": "ds-segment-bar"
      },
      "variants": {
        "type": ["segment-control", "chips", "filters"],
        "size": ["sm", "md", "lg"]
      },
      "dataAttributes": ["data-component", "data-variant", "data-size"]
    },
    "Thumbnail": {
      "category": "atomic",
      "description": "Avatar or image thumbnail with sizes and optional rounded corners",
      "platforms": {
        "web": "app/components/Thumbnail/Thumbnail.tsx",
        "ios": "Components/Thumbnail/AppThumbnail.swift",
        "android": "ui/components/AppThumbnail.kt"
      },
      "html": {
        "css": "components/thumbnail/thumbnail.css",
        "snippet": "components/thumbnail/thumbnail.html",
        "tag": "div",
        "classPrefix": "ds-thumbnail"
      },
      "variants": {
        "size": ["xs", "sm", "md", "lg", "xl", "xxl"],
        "rounded": ["off", "on"]
      },
      "dataAttributes": ["data-component", "data-size", "data-rounded"]
    },
    "InputField": {
      "category": "atomic",
      "description": "Text input with leading/trailing slots, multiple states and types",
      "platforms": {
        "web": "app/components/InputField/InputField.tsx",
        "ios": "Components/InputField/AppInputField.swift",
        "android": "ui/components/AppInputField.kt"
      },
      "html": {
        "css": "components/input-field/input-field.css",
        "snippet": "components/input-field/input-field.html",
        "tag": "div",
        "classPrefix": "ds-input-wrapper"
      },
      "variants": {
        "state": ["default", "focus", "filled", "success", "warning", "error", "disabled"],
        "type": ["default", "text-field"]
      },
      "dataAttributes": ["data-component", "data-state", "data-type"]
    },
    "Toast": {
      "category": "atomic",
      "description": "Notification toast with type, optional action, and dismiss button",
      "platforms": {
        "web": "app/components/Toast/Toast.tsx",
        "ios": "Components/Toast/AppToast.swift",
        "android": "ui/components/AppToast.kt"
      },
      "html": {
        "css": "components/toast/toast.css",
        "snippet": "components/toast/toast.html",
        "tag": "div",
        "classPrefix": "ds-toast"
      },
      "variants": {
        "type": ["default", "success", "warning", "error", "info"],
        "hasAction": ["false", "true"],
        "hasDismiss": ["false", "true"]
      },
      "dataAttributes": ["data-component", "data-variant", "data-has-action", "data-has-dismiss"]
    },
    "DateGrid": {
      "category": "atomic",
      "description": "7-cell week strip date picker with date items and navigation arrows",
      "platforms": {
        "web": "app/components/DateGrid/DateGrid.tsx",
        "ios": "Components/DateGrid/AppDateGrid.swift",
        "android": "ui/components/AppDateGrid.kt"
      },
      "html": {
        "css": "components/date-grid/date-grid.css",
        "snippet": "components/date-grid/date-grid.html",
        "tag": "div",
        "classPrefix": "ds-date-grid"
      },
      "variants": {
        "state": ["default", "active", "disabled"],
        "toggle": ["off", "on"]
      },
      "dataAttributes": ["data-component", "data-active", "data-state"]
    },
    "Divider": {
      "category": "atomic",
      "description": "Horizontal or vertical divider line, section or row style",
      "platforms": {
        "web": "app/components/Divider/Divider.tsx",
        "ios": "Components/Divider/AppDivider.swift",
        "android": "ui/components/AppDivider.kt"
      },
      "html": {
        "css": "components/divider/divider.css",
        "snippet": "components/divider/divider.html",
        "tag": "hr",
        "classPrefix": "ds-divider"
      },
      "variants": {
        "type": ["section", "row"],
        "orientation": ["horizontal", "vertical"]
      },
      "dataAttributes": ["data-component", "data-variant", "data-orientation"]
    },
    "Checkbox": {
      "category": "atomic",
      "description": "Checkbox with checked, unchecked, and indeterminate states",
      "platforms": {
        "web": "app/components/Checkbox/Checkbox.tsx",
        "ios": "Components/Checkbox/AppCheckbox.swift",
        "android": "ui/components/AppCheckbox.kt"
      },
      "html": {
        "css": "components/checkbox/checkbox.css",
        "snippet": "components/checkbox/checkbox.html",
        "tag": "label",
        "classPrefix": "ds-checkbox"
      },
      "variants": {
        "state": ["unchecked", "checked", "indeterminate"],
        "disabled": ["false", "true"]
      },
      "dataAttributes": ["data-component", "data-state", "data-disabled"]
    },
    "Switch": {
      "category": "atomic",
      "description": "Toggle switch with on/off state and disabled variant",
      "platforms": {
        "web": "app/components/Switch/Switch.tsx",
        "ios": "Components/Switch/AppSwitch.swift",
        "android": "ui/components/AppSwitch.kt"
      },
      "html": {
        "css": "components/switch/switch.css",
        "snippet": "components/switch/switch.html",
        "tag": "label",
        "classPrefix": "ds-switch"
      },
      "variants": {
        "state": ["off", "on"],
        "disabled": ["false", "true"]
      },
      "dataAttributes": ["data-component", "data-state", "data-disabled"]
    },
    "RadioButton": {
      "category": "atomic",
      "description": "Radio button with selected/unselected states and RadioGroup container",
      "platforms": {
        "web": "app/components/RadioButton/RadioButton.tsx",
        "ios": "Components/RadioButton/AppRadioButton.swift",
        "android": "ui/components/AppRadioButton.kt"
      },
      "html": {
        "css": "components/radio-button/radio-button.css",
        "snippet": "components/radio-button/radio-button.html",
        "tag": "label",
        "classPrefix": "ds-radio"
      },
      "variants": {
        "state": ["unselected", "selected"],
        "disabled": ["false", "true"]
      },
      "dataAttributes": ["data-component", "data-state", "data-disabled"]
    }
  },
  "patterns": {
    "TextBlock": {
      "category": "pattern",
      "description": "Typography-only layout pattern with overline, title, subtext, body, and metadata slots",
      "composes": [],
      "platforms": {
        "web": "app/components/patterns/TextBlock/TextBlock.tsx",
        "ios": "Components/Patterns/AppTextBlock.swift",
        "android": "ui/patterns/AppTextBlock.kt"
      },
      "html": {
        "css": "patterns/text-block/text-block.css",
        "snippet": "patterns/text-block/text-block.html",
        "tag": "div",
        "classPrefix": "ds-text-block"
      },
      "variants": {
        "slots": ["overline", "title", "subtext", "body", "metadata"]
      },
      "dataAttributes": ["data-component", "data-variant"]
    },
    "StepIndicator": {
      "category": "pattern",
      "description": "Single step indicator with completed/incomplete state",
      "composes": [],
      "platforms": {
        "web": "app/components/patterns/StepIndicator/StepIndicator.tsx",
        "ios": "Components/Patterns/AppStepIndicator.swift",
        "android": "ui/patterns/AppStepIndicator.kt"
      },
      "html": {
        "css": "patterns/step-indicator/step-indicator.css",
        "snippet": "patterns/step-indicator/step-indicator.html",
        "tag": "div",
        "classPrefix": "ds-step-indicator"
      },
      "variants": {
        "state": ["default", "completed"]
      },
      "dataAttributes": ["data-component", "data-state"]
    },
    "Stepper": {
      "category": "pattern",
      "description": "Multi-step timeline composing TextBlock and StepIndicator",
      "composes": ["TextBlock", "StepIndicator"],
      "platforms": {
        "web": "app/components/patterns/Stepper/Stepper.tsx",
        "ios": "Components/Patterns/AppStepper.swift",
        "android": "ui/patterns/AppStepper.kt"
      },
      "html": {
        "css": "patterns/stepper/stepper.css",
        "snippet": "patterns/stepper/stepper.html",
        "tag": "div",
        "classPrefix": "ds-stepper"
      },
      "variants": {
        "stepState": ["default", "completed"]
      },
      "dataAttributes": ["data-component", "data-step-state"]
    },
    "ListItem": {
      "category": "pattern",
      "description": "Row pattern composing leading avatar, text content, trailing actions, and optional divider",
      "composes": ["TextBlock", "Thumbnail", "Button", "IconButton", "Badge", "Divider"],
      "platforms": {
        "web": "app/components/patterns/ListItem/ListItem.tsx",
        "ios": "Components/Patterns/AppListItem.swift",
        "android": "ui/patterns/AppListItem.kt"
      },
      "html": {
        "css": "patterns/list-item/list-item.css",
        "snippet": "patterns/list-item/list-item.html",
        "tag": "div",
        "classPrefix": "ds-list-item"
      },
      "variants": {
        "leading": ["none", "thumbnail"],
        "trailing": ["none", "badge", "icon-button", "button"]
      },
      "dataAttributes": ["data-component", "data-leading", "data-trailing"]
    }
  },
  "designTools": {
    "DeviceFrame": {
      "category": "design-tool",
      "description": "iPhone device frame shells for wrapping screen mockups",
      "html": {
        "css": "design-tools/device-frames/device-frames.css",
        "snippet": "design-tools/device-frames/device-frames.html",
        "tag": "div",
        "classPrefix": "ds-device"
      },
      "variants": {
        "model": ["iphone", "iphone-pro-max"]
      },
      "dataAttributes": ["data-component", "data-model"]
    },
    "Annotation": {
      "category": "design-tool",
      "description": "Callout annotation overlays for design documentation with color and arrow variants",
      "html": {
        "css": "design-tools/annotations/annotations.css",
        "snippet": "design-tools/annotations/annotations.html",
        "tag": "div",
        "classPrefix": "ds-callout"
      },
      "variants": {
        "color": ["red", "blue", "green", "yellow", "purple"],
        "arrow": ["none", "arrow-up", "arrow-down"]
      },
      "dataAttributes": ["data-component", "data-color", "data-arrow"]
    },
    "SlideLayout": {
      "category": "design-tool",
      "description": "Presentation slide layouts: title, content, and split variants",
      "html": {
        "css": "design-tools/slide-layouts/slide-layouts.css",
        "snippet": "design-tools/slide-layouts/slide-layouts.html",
        "tag": "div",
        "classPrefix": "ds-slide"
      },
      "variants": {
        "layout": ["title-slide", "content-slide", "split-slide"]
      },
      "dataAttributes": ["data-component", "data-layout"]
    },
    "Wireframe": {
      "category": "design-tool",
      "description": "Grayscale wireframe scaffolding elements: nav, tab bar, and layout primitives",
      "html": {
        "css": "design-tools/wireframe/wireframe.css",
        "snippet": "design-tools/wireframe/wireframe.html",
        "tag": "div",
        "classPrefix": "ds-wireframe-nav"
      },
      "variants": {
        "navItem": ["default", "active"],
        "tabItem": ["default", "active"]
      },
      "dataAttributes": ["data-component", "data-active"]
    }
  }
}
